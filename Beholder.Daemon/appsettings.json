{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Recording": {
    "FilterSelfTraffic": true
  },
  "Rollup": {
    "Preset": "Balanced"
  },
  "TrafficStorage": {
    "IdleDestinationTimeoutMinutes": 5,
    "IdleProcessTimeoutHours": 1
  }
}
