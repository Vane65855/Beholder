{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Recording": {
    "FilterSelfTraffic": true
  },
  "Rollup": {
    "Preset": "Balanced"
  },
  "TrafficStorage": {
    "IdleDestinationTimeoutMinutes": 5,
    "IdleProcessTimeoutHours": 1
  },
  "Alert": {
    "EnableNewProcessDetection": true,
    "EnableHashChangeDetection": true,
    "EnableChainIntegrityMonitor": true,
    "BinaryHashCheckIntervalMinutes": 60,
    "ChainVerifyIntervalMinutes": 60,
    "MaxFileHashTimeoutSeconds": 5
  }
}
