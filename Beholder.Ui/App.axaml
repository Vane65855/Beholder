<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Beholder.Ui.App"
             xmlns:local="using:Beholder.Ui"
             xmlns:converters="using:Beholder.Ui.Converters"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <converters:DoubleToGridLengthConverter x:Key="RatioToGridLength" />
            <converters:SeriesIndexToBrushConverter x:Key="SeriesToBrush" />
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Beholder.Ui/Themes/DarkTheme.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
