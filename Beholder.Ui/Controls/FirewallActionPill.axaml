<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Beholder.Ui.Controls.FirewallActionPill">

    <UserControl.Styles>
        <!-- Base pill style: monospace caps, narrow padding, subtle border. The
             three state-specific classes (.allow / .block / .default) flip the
             foreground + border tokens; background stays transparent so the
             pill blends with rows in either Active or Inactive groups. -->
        <!-- Width=76 (not MinWidth) per UI_QUALITY_STANDARDS §2.5: fixed-target
             buttons with text changes (ALLOW ↔ BLOCK) use explicit Width to
             prevent layout shift across state transitions. The dependent
             column widths in FirewallTabView.axaml are 84 (IN: 76 + 8 margin)
             and 88 (OUT: 76 + 12 margin) — keep them in sync if Width changes. -->
        <Style Selector="Button.firewallPill">
            <Setter Property="Width" Value="76" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>
        <Style Selector="Button.firewallPill.allow">
            <Setter Property="Foreground" Value="{DynamicResource SeveritySuccess}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SeveritySuccess}" />
        </Style>
        <Style Selector="Button.firewallPill.block">
            <Setter Property="Foreground" Value="{DynamicResource SeverityDanger}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SeverityDanger}" />
        </Style>
        <!-- No "default" style: rows with no rule are visually identical to rows
             with an explicit Allow rule (both show ALLOW green). The pill is a
             status indicator for effective connectivity, not the underlying
             rule state — "no rule" means Windows defaults to allow. -->
        <Style Selector="Button.firewallPill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
        </Style>
    </UserControl.Styles>

    <Button x:Name="PillButton"
            Classes="firewallPill"
            Click="OnClick" />
</UserControl>
