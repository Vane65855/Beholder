<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Beholder.Ui.ViewModels"
             xmlns:controls="using:Beholder.Ui.Controls"
             x:Class="Beholder.Ui.Views.Tabs.SettingsTabView"
             x:DataType="vm:SettingsTabViewModel"
             Background="{DynamicResource BackgroundRoot}">

    <UserControl.Styles>
        <!-- ═════ Section card chrome ═════
             3-px left-edge stripe (Severity Rail pattern from UI_DESIGN
             §5.1, applied at section level) + 1-px outline on the other
             three sides. Each section adds an "accent*" class that
             overrides the stripe color. -->
        <Style Selector="Border.sectionCard">
            <Setter Property="Background" Value="{DynamicResource BackgroundPanel}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1,1,1,1" />
            <Setter Property="Padding" Value="24,20" />
            <Setter Property="CornerRadius" Value="2" />
        </Style>
        <!-- The accent stripe is a dedicated thin Border placed inside
             each section so the card's own border can stay 1px on all
             sides; pure XAML doesn't let us set a per-edge BorderBrush. -->
        <Style Selector="Border.accentStripe">
            <Setter Property="Width" Value="3" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="-24,-20,0,-20" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>
        <Style Selector="Border.accentStripe.cyan">
            <Setter Property="Background" Value="{DynamicResource AccentPrimary}" />
        </Style>
        <Style Selector="Border.accentStripe.amber">
            <Setter Property="Background" Value="{DynamicResource SeverityWarn}" />
        </Style>
        <Style Selector="Border.accentStripe.neutral">
            <Setter Property="Background" Value="{DynamicResource BorderStrong}" />
        </Style>

        <!-- ═════ Typography ═════ -->
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="LetterSpacing" Value="2" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>
        <Style Selector="TextBlock.subsectionTitle">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="LetterSpacing" Value="2" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="TextBlock.fieldLabel">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="LetterSpacing" Value="2" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>

        <!-- ═════ Action button (mirrors Scanner tab's scanButton) ═════ -->
        <Style Selector="Button.actionButton">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="LetterSpacing" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}" />
        </Style>
        <Style Selector="Button.actionButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
        </Style>
        <Style Selector="Button.actionButton:disabled">
            <Setter Property="Opacity" Value="0.5" />
            <Setter Property="Cursor" Value="Arrow" />
        </Style>

        <!-- ═════ Icon button (copy-to-clipboard) ═════ -->
        <Style Selector="Button.iconButton">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        </Style>
        <Style Selector="Button.iconButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
        </Style>

        <!-- ═════ Inline link (clickable URL) ═════ -->
        <Style Selector="Button.link">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style Selector="Button.link:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource AccentHover}" />
        </Style>
        <Style Selector="Button.link:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- ═════ Chain-status pill (#7) ═════
             Background brush comes from a string key on the VM resolved
             at bind time via BrushKeyConverter. BrushTransition makes
             the color change smooth when verify flips state — pulse
             without scripting (#25). -->
        <Style Selector="Border.statusPill">
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.3" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.statusPill TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="LetterSpacing" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}" />
        </Style>

        <!-- ═════ Stacked total bar / per-row bar ═════ -->
        <Style Selector="Border.barSegment">
            <Setter Property="Height" Value="8" />
            <Setter Property="CornerRadius" Value="1" />
        </Style>
        <Style Selector="Border.barTrack">
            <Setter Property="Height" Value="6" />
            <Setter Property="CornerRadius" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <!-- ═════ MOTD-style top strip (#20) ═════ -->
        <Style Selector="Border.motdStrip">
            <Setter Property="Background" Value="{DynamicResource BackgroundNavBar}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="24,8" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
        <Style Selector="Border.motdStrip TextBlock">
            <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="Border.motdPill">
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.3" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.motdPill TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="LetterSpacing" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnAccent}" />
        </Style>

        <!-- ═════ Cascade sparkline (#19) ═════
             Five thin vertical bars inline next to the TRAFFIC ROLLUP
             subheader. Each bar is bound to one of the five
             CascadeRatios via the SparklineBar style and a positional
             ContentControl in the data template. -->
        <Style Selector="Border.sparklineBar">
            <Setter Property="Width" Value="4" />
            <Setter Property="Background" Value="{DynamicResource AccentPrimary}" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="CornerRadius" Value="1" />
            <Setter Property="Opacity" Value="0.7" />
        </Style>

    </UserControl.Styles>

    <Grid>
        <!-- ═════ Sticky-header overlay (#13) ═════
             Sits on top of the ScrollViewer in z-order. Visibility +
             text managed by SettingsTabView.axaml.cs's ScrollChanged
             handler. -->
        <Border x:Name="StickyHeader"
                ZIndex="10"
                VerticalAlignment="Top"
                Background="{DynamicResource BackgroundElevated}"
                BorderBrush="{DynamicResource DividerHorizontal}"
                BorderThickness="0,0,0,1"
                Padding="24,10"
                IsVisible="False">
            <TextBlock x:Name="StickyHeaderText" Classes="sectionTitle" Text="DATA STORAGE" />
        </Border>

        <DockPanel>
            <controls:ErrorBanner DockPanel.Dock="Top"
                                  Severity="Danger"
                                  Message="{Binding ErrorMessage}"
                                  IsVisible="{Binding HasError}"
                                  DismissCommand="{Binding DismissErrorCommand}" />

            <Panel IsVisible="{Binding ShowLoadingState}">
                <TextBlock Text="Loading settings…"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="{DynamicResource FontSizeHeading}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Panel>

            <ScrollViewer x:Name="SettingsScrollViewer"
                          IsVisible="{Binding ShowPopulatedState}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Orientation="Vertical">

                    <!-- ════════════════  MOTD strip (#20)  ════════════════ -->
                    <Border Classes="motdStrip">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="BEHOLDER NMT"
                                       Foreground="{DynamicResource AccentPrimary}"
                                       FontWeight="SemiBold"
                                       LetterSpacing="1" />
                            <TextBlock Text="·" Foreground="{DynamicResource TextMuted}" />
                            <TextBlock Text="{Binding AboutInfo.Version, StringFormat='v{0}'}" />
                            <TextBlock Text="·" Foreground="{DynamicResource TextMuted}" />
                            <TextBlock Text="{Binding UptimeLabel, StringFormat='uptime {0}'}" />
                            <TextBlock Text="·" Foreground="{DynamicResource TextMuted}" />
                            <TextBlock Text="chain" />
                            <Border Classes="motdPill"
                                    Background="{Binding ChainStatus.StatusPillBrushKey,
                                        Converter={StaticResource BrushKeyConverter}}">
                                <TextBlock Text="{Binding ChainStatus.StatusPillLabel}" />
                            </Border>
                            <TextBlock Text="·" Foreground="{DynamicResource TextMuted}" />
                            <TextBlock Text="{Binding LanDeviceCountLabel}" />
                        </StackPanel>
                    </Border>

                    <!-- ════════════════  Sections (full-width single column)  ════════════════
                         Phase 13.1.2 dropped the 2-column responsive layout
                         (Phase 13.1.1 item #12) — Settings is read top-to-
                         bottom and the full-width Data Storage card gives
                         the proportional bars the horizontal space they need
                         to communicate proportion. -->
                    <StackPanel Orientation="Vertical" Spacing="24">

                        <!-- ──────────  DATA STORAGE  ────────── -->
                        <Border x:Name="DataStorageCard" Classes="sectionCard">
                            <Grid>
                                <Border Classes="accentStripe cyan" />
                                <StackPanel Orientation="Vertical" Spacing="16">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                    Spacing="14" VerticalAlignment="Center">
                                            <TextBlock Classes="sectionTitle" Text="DATA STORAGE"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding DatabaseBytesTotalFormatted}"
                                                       FontSize="{DynamicResource FontSizeHeading}"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                       VerticalAlignment="Center"
                                                       ToolTip.Tip="On-disk size of the SQLite database file. WAL sidecars are not counted; SQLite periodically rolls their contents back into the main file." />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="2"
                                                    HorizontalAlignment="Right">
                                            <Button Classes="actionButton"
                                                    Content="REFRESH"
                                                    MinWidth="100"
                                                    Command="{Binding RefreshStorageStatsCommand}"
                                                    IsEnabled="{Binding !IsRefreshing}"
                                                    ToolTip.Tip="Re-fetch per-table row counts and the database file size from the daemon." />
                                            <TextBlock Text="{Binding LastRefreshedAtLabel}"
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Stacked total bar (#11) — 3 colored segments
                                         using star-unit grid columns bound to ratios. -->
                                    <Border Classes="barTrack">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="{Binding TrafficTierRatio,
                                                    Converter={StaticResource RatioToGridLength}}" />
                                                <ColumnDefinition Width="{Binding AuditChainRatio,
                                                    Converter={StaticResource RatioToGridLength}}" />
                                                <ColumnDefinition Width="{Binding OtherTablesRatio,
                                                    Converter={StaticResource RatioToGridLength}}" />
                                            </Grid.ColumnDefinitions>
                                            <Rectangle Grid.Column="0"
                                                       Fill="{DynamicResource AccentPrimary}" />
                                            <Rectangle Grid.Column="1"
                                                       Fill="{DynamicResource ChartInboundStroke}" />
                                            <Rectangle Grid.Column="2"
                                                       Fill="{DynamicResource BorderStrong}" />
                                        </Grid>
                                    </Border>

                                    <!-- TRAFFIC ROLLUP subheader + cascade sparkline (#19) -->
                                    <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,8,0,0">
                                        <TextBlock Classes="subsectionTitle"
                                                   Text="TRAFFIC ROLLUP"
                                                   VerticalAlignment="Center" />
                                        <Border Height="16" Width="32" VerticalAlignment="Center">
                                            <Grid ColumnDefinitions="*,*,*,*,*"
                                                  ColumnSpacing="2"
                                                  VerticalAlignment="Bottom">
                                                <Border Grid.Column="0" Classes="sparklineBar"
                                                        Height="{Binding CascadeRatios[0],
                                                            Converter={StaticResource RatioToGridLength}}" />
                                                <Border Grid.Column="1" Classes="sparklineBar"
                                                        Height="{Binding CascadeRatios[1],
                                                            Converter={StaticResource RatioToGridLength}}" />
                                                <Border Grid.Column="2" Classes="sparklineBar"
                                                        Height="{Binding CascadeRatios[2],
                                                            Converter={StaticResource RatioToGridLength}}" />
                                                <Border Grid.Column="3" Classes="sparklineBar"
                                                        Height="{Binding CascadeRatios[3],
                                                            Converter={StaticResource RatioToGridLength}}" />
                                                <Border Grid.Column="4" Classes="sparklineBar"
                                                        Height="{Binding CascadeRatios[4],
                                                            Converter={StaticResource RatioToGridLength}}" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <!-- Traffic-tier rows -->
                                    <ItemsControl ItemsSource="{Binding TrafficTables}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TableStatsRow">
                                                <Grid ColumnDefinitions="2*,80,3*,Auto"
                                                      ColumnSpacing="16"
                                                      Margin="0,6">
                                                    <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="1">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="{DynamicResource FontSizeBody}"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   ToolTip.Tip="{Binding Description}" />
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="{DynamicResource FontSizeCaption}"
                                                                   Foreground="{DynamicResource TextMuted}"
                                                                   FontFamily="Cascadia Code, Consolas, monospace" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Retention}"
                                                               FontSize="{DynamicResource FontSizeCaption}"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               VerticalAlignment="Center" />
                                                    <Border Grid.Column="2" Classes="barTrack" VerticalAlignment="Center" MinWidth="120">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="{Binding RowCountShareRatio,
                                                                    Converter={StaticResource RatioToGridLength}}" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Rectangle Grid.Column="0"
                                                                       Fill="{DynamicResource AccentPrimary}" />
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding RowCountFormatted}"
                                                               FontSize="{DynamicResource FontSizeBody}"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontFamily="Cascadia Code, Consolas, monospace"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"
                                                               MinWidth="80" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- AUDIT & STATE subheader -->
                                    <TextBlock Classes="subsectionTitle"
                                               Text="AUDIT &amp; STATE"
                                               Margin="0,16,0,0" />

                                    <!-- Flat-table rows (same template shape but tinted differently) -->
                                    <ItemsControl ItemsSource="{Binding FlatTables}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:TableStatsRow">
                                                <Grid ColumnDefinitions="2*,80,3*,Auto"
                                                      ColumnSpacing="16"
                                                      Margin="0,6">
                                                    <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="1">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="{DynamicResource FontSizeBody}"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   ToolTip.Tip="{Binding Description}" />
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="{DynamicResource FontSizeCaption}"
                                                                   Foreground="{DynamicResource TextMuted}"
                                                                   FontFamily="Cascadia Code, Consolas, monospace" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Retention}"
                                                               FontSize="{DynamicResource FontSizeCaption}"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               VerticalAlignment="Center" />
                                                    <Border Grid.Column="2" Classes="barTrack" VerticalAlignment="Center" MinWidth="120">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="{Binding RowCountShareRatio,
                                                                    Converter={StaticResource RatioToGridLength}}" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Rectangle Grid.Column="0"
                                                                       Fill="{DynamicResource ChartInboundStroke}" />
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding RowCountFormatted}"
                                                               FontSize="{DynamicResource FontSizeBody}"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontFamily="Cascadia Code, Consolas, monospace"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"
                                                               MinWidth="80" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ──────────  RECORDING  ────────── -->
                        <Border x:Name="RecordingCard" Classes="sectionCard">
                            <Grid>
                                <Border Classes="accentStripe cyan" />
                                <StackPanel Orientation="Vertical" Spacing="16">
                                    <TextBlock Classes="sectionTitle" Text="RECORDING" />

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="4"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Filter own traffic"
                                                       FontSize="{DynamicResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="When on, Beholder's daemon and UI processes are excluded from the flow event pipeline so their traffic doesn't pollute charts."
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <controls:SettingsTogglePill Grid.Column="1"
                                                                     IsOn="{Binding Recording.FilterSelfTraffic}"
                                                                     IsSaving="{Binding Recording.IsSaving}"
                                                                     Command="{Binding ToggleFilterSelfTrafficCommand}"
                                                                     VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ──────────  HOSTNAME RESOLUTION  ────────── -->
                        <Border x:Name="HostnameResolutionCard" Classes="sectionCard">
                            <Grid>
                                <Border Classes="accentStripe cyan" />
                                <StackPanel Orientation="Vertical" Spacing="16">
                                    <TextBlock Classes="sectionTitle" Text="HOSTNAME RESOLUTION" />

                                    <!-- EnableReverseDnsFallback (LIVE) -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="4"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Reverse-DNS fallback"
                                                       FontSize="{DynamicResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="On a DNS-cache miss, issue a reverse-DNS lookup so direct-IP destinations show a hostname when one is available."
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <controls:SettingsTogglePill Grid.Column="1"
                                                                     IsOn="{Binding HostnameResolution.EnableReverseDnsFallback}"
                                                                     IsSaving="{Binding HostnameResolution.IsSavingReverseDnsFallback}"
                                                                     Command="{Binding ToggleEnableReverseDnsFallbackCommand}"
                                                                     VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- EnablePreload (RESTART REQUIRED) -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="4"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Preload from Windows DNS cache"
                                                       FontSize="{DynamicResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="At daemon start, seed the in-memory DNS cache from Windows's own resolver cache so historical lookups don't need a fresh query."
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="(takes effect on next daemon start)"
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource SeverityWarn}"
                                                       FontStyle="Italic" />
                                        </StackPanel>
                                        <controls:SettingsTogglePill Grid.Column="1"
                                                                     IsOn="{Binding HostnameResolution.EnablePreload}"
                                                                     IsSaving="{Binding HostnameResolution.IsSavingPreload}"
                                                                     Command="{Binding ToggleEnablePreloadCommand}"
                                                                     VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- EnableSniCapture (RESTART REQUIRED) -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="4"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="SNI capture"
                                                       FontSize="{DynamicResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="Run the PktMon ETW session that extracts SNI hostnames from TLS ClientHello packets — useful when DNS over HTTPS hides resolver traffic."
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="(takes effect on next daemon start)"
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource SeverityWarn}"
                                                       FontStyle="Italic" />
                                        </StackPanel>
                                        <controls:SettingsTogglePill Grid.Column="1"
                                                                     IsOn="{Binding HostnameResolution.EnableSniCapture}"
                                                                     IsSaving="{Binding HostnameResolution.IsSavingSniCapture}"
                                                                     Command="{Binding ToggleEnableSniCaptureCommand}"
                                                                     VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ──────────  ALERTS  ────────── -->
                        <Border x:Name="AlertsCard" Classes="sectionCard">
                            <Grid>
                                <Border Classes="accentStripe cyan" />
                                <StackPanel Orientation="Vertical" Spacing="16">
                                    <TextBlock Classes="sectionTitle" Text="ALERTS" />

                                    <!-- EnableNewProcessDetection (LIVE, per-event) -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="4"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="New process detection"
                                                       FontSize="{DynamicResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="Fire an alert the first time a binary touches the network. Turn off if your machine constantly spawns new binaries (e.g., dev box compiling+running fresh executables)."
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <controls:SettingsTogglePill Grid.Column="1"
                                                                     IsOn="{Binding Alerts.EnableNewProcessDetection}"
                                                                     IsSaving="{Binding Alerts.IsSavingNewProcessDetection}"
                                                                     Command="{Binding ToggleEnableNewProcessDetectionCommand}"
                                                                     VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- EnableHashChangeDetection (LIVE, per-tick) -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="4"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Hash-change detection"
                                                       FontSize="{DynamicResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="Re-hash tracked binaries periodically and alert when the SHA-256 changes (covers both straight-up tampering and the Phase 7.5 publisher-mismatch spoof case)."
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <controls:SettingsTogglePill Grid.Column="1"
                                                                     IsOn="{Binding Alerts.EnableHashChangeDetection}"
                                                                     IsSaving="{Binding Alerts.IsSavingHashChangeDetection}"
                                                                     Command="{Binding ToggleEnableHashChangeDetectionCommand}"
                                                                     VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- EnableChainIntegrityMonitor (LIVE, per-tick — mandatory startup verify ALWAYS runs) -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="4"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Chain integrity periodic verify"
                                                       FontSize="{DynamicResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="Re-verify the chain-hashed event log periodically and alert on mismatch. The mandatory startup verify always runs regardless of this toggle (Phase 13.3 hardening — a corrupt chain shouldn't be hideable via a UI flip)."
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <controls:SettingsTogglePill Grid.Column="1"
                                                                     IsOn="{Binding Alerts.EnableChainIntegrityMonitor}"
                                                                     IsSaving="{Binding Alerts.IsSavingChainIntegrityMonitor}"
                                                                     Command="{Binding ToggleEnableChainIntegrityMonitorCommand}"
                                                                     VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ──────────  SCANNER  ────────── -->
                        <Border x:Name="ScannerCard" Classes="sectionCard">
                            <Grid>
                                <Border Classes="accentStripe cyan" />
                                <StackPanel Orientation="Vertical" Spacing="16">
                                    <TextBlock Classes="sectionTitle" Text="SCANNER" />

                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="4"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Hostname resolution"
                                                       FontSize="{DynamicResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock Text="On each LAN scan, run mDNS service-discovery + the per-IP hostname ladder (mDNS-PTR, NetBIOS, router-DNS) to populate device names. Disable for pure passive discovery — hostnames will stay empty for newly observed devices."
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                        <controls:SettingsTogglePill Grid.Column="1"
                                                                     IsOn="{Binding Scanner.EnableHostnameResolution}"
                                                                     IsSaving="{Binding Scanner.IsSavingHostnameResolution}"
                                                                     Command="{Binding ToggleEnableHostnameResolutionCommand}"
                                                                     VerticalAlignment="Center" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ──────────  APPLICATION IDENTITY OVERRIDES (Phase 13.6, ADR 011)  ────────── -->
                        <Border x:Name="AppIdentityCard" Classes="sectionCard">
                            <Grid>
                                <Border Classes="accentStripe cyan" />
                                <StackPanel Orientation="Vertical" Spacing="16">
                                    <TextBlock Classes="sectionTitle" Text="APPLICATION IDENTITY OVERRIDES" />
                                    <TextBlock Text="Tell Beholder that a binary is the same app across version subfolders (e.g. Squirrel auto-updaters). Versions matching a rule won't fire 'new process' alerts on each update."
                                               FontSize="{DynamicResource FontSizeCaption}"
                                               Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap" />

                                    <!-- READ MODE: rule list + ADD button -->
                                    <StackPanel Orientation="Vertical" Spacing="12"
                                                IsVisible="{Binding !AppIdentityRules.IsAdding}">
                                        <Button Classes="actionButton"
                                                Content="+ ADD RULE"
                                                HorizontalAlignment="Left"
                                                Command="{Binding BeginAddAppIdentityRuleCommand}" />

                                        <!-- Empty state -->
                                        <TextBlock Text="No rules yet. Add a rule to silence repeated 'new process' alerts on Squirrel-style auto-updaters."
                                                   FontSize="{DynamicResource FontSizeCaption}"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontStyle="Italic"
                                                   IsVisible="{Binding !AppIdentityRules.Rules.Count}" />

                                        <!-- Rules list -->
                                        <ItemsControl ItemsSource="{Binding AppIdentityRules.Rules}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:AppIdentityRuleRow">
                                                    <Border Background="{DynamicResource BackgroundPanel}"
                                                            BorderBrush="{DynamicResource BorderSubtle}"
                                                            BorderThickness="0,1,0,0"
                                                            Padding="0,12">
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="3">
                                                                <TextBlock Text="{Binding Label}"
                                                                           FontSize="{DynamicResource FontSizeBody}"
                                                                           Foreground="{DynamicResource TextPrimary}" />
                                                                <TextBlock Text="{Binding AnchorPath}"
                                                                           FontSize="{DynamicResource FontSizeCaption}"
                                                                           FontFamily="Cascadia Code, Consolas, monospace"
                                                                           Foreground="{DynamicResource TextSecondary}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding Filename}"
                                                                           FontSize="{DynamicResource FontSizeCaption}"
                                                                           FontFamily="Cascadia Code, Consolas, monospace"
                                                                           Foreground="{DynamicResource TextMuted}" />
                                                            </StackPanel>
                                                            <Button Grid.Column="1"
                                                                    Classes="actionButton"
                                                                    Content="REMOVE"
                                                                    MinWidth="80"
                                                                    VerticalAlignment="Center"
                                                                    Command="{Binding $parent[ItemsControl].((vm:SettingsTabViewModel)DataContext).RemoveAppIdentityRuleCommand}"
                                                                    CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- ADD MODE: input form -->
                                    <StackPanel Orientation="Vertical" Spacing="12"
                                                IsVisible="{Binding AppIdentityRules.IsAdding}">
                                        <TextBlock Text="ADD RULE"
                                                   FontSize="{DynamicResource FontSizeCaption}"
                                                   LetterSpacing="2"
                                                   Foreground="{DynamicResource TextSecondary}" />

                                        <!-- PICKED FILE + Browse button -->
                                        <Grid ColumnDefinitions="140,Auto,*" ColumnSpacing="12">
                                            <TextBlock Grid.Column="0" Classes="fieldLabel" Text="PICKED FILE"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Classes="actionButton"
                                                    Content="BROWSE…"
                                                    Command="{Binding PickAppIdentityFileCommand}" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AppIdentityRules.PickedFilePath}"
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>

                                        <!-- Derived fields + editable anchor — only visible once a file is picked -->
                                        <StackPanel Orientation="Vertical" Spacing="10"
                                                    IsVisible="{Binding AppIdentityRules.HasPickedFile}">
                                            <Grid ColumnDefinitions="140,*" ColumnSpacing="12">
                                                <TextBlock Grid.Column="0" Classes="fieldLabel" Text="FILE" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding AppIdentityRules.Filename}"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           FontFamily="Cascadia Code, Consolas, monospace"
                                                           Foreground="{DynamicResource TextPrimary}" />
                                            </Grid>

                                            <Grid ColumnDefinitions="140,*" ColumnSpacing="12">
                                                <TextBlock Grid.Column="0" Classes="fieldLabel" Text="VARIABLE" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding AppIdentityRules.VariableSegment}"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           FontFamily="Cascadia Code, Consolas, monospace"
                                                           Foreground="{DynamicResource TextSecondary}" />
                                            </Grid>

                                            <Grid ColumnDefinitions="140,*" ColumnSpacing="12">
                                                <TextBlock Grid.Column="0" Classes="fieldLabel" Text="ANCHOR" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding AppIdentityRules.AnchorPath, Mode=TwoWay}"
                                                         FontSize="{DynamicResource FontSizeBody}"
                                                         FontFamily="Cascadia Code, Consolas, monospace" />
                                            </Grid>

                                            <Grid ColumnDefinitions="140,*" ColumnSpacing="12">
                                                <TextBlock Grid.Column="0" Classes="fieldLabel" Text="DISPLAY NAME" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding AppIdentityRules.DisplayName, Mode=TwoWay}"
                                                         FontSize="{DynamicResource FontSizeBody}"
                                                         PlaceholderText="(optional)" />
                                            </Grid>

                                            <!-- Live match preview -->
                                            <TextBlock Text="{Binding AppIdentityRules.MatchPreview}"
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap" />

                                            <!-- Validation error -->
                                            <TextBlock Text="{Binding AppIdentityRules.ValidationError}"
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource SeverityDanger}"
                                                       IsVisible="{Binding AppIdentityRules.HasValidationError}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <!-- Action buttons -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                            <Button Classes="actionButton"
                                                    Content="CANCEL"
                                                    Command="{Binding CancelAddAppIdentityRuleCommand}" />
                                            <Button Classes="actionButton"
                                                    Content="SAVE"
                                                    IsEnabled="{Binding AppIdentityRules.CanSave}"
                                                    Command="{Binding SaveAppIdentityRuleCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ──────────  MAINTENANCE  ────────── -->
                        <Border x:Name="MaintenanceCard" Classes="sectionCard">
                            <Grid>
                                <Border Classes="accentStripe amber" />
                                <StackPanel Orientation="Vertical" Spacing="20">
                                    <TextBlock Classes="sectionTitle" Text="MAINTENANCE" />

                                    <!-- Chain integrity row -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="6"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Chain integrity"
                                                       FontSize="{DynamicResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Border Classes="statusPill"
                                                        Background="{Binding ChainStatus.StatusPillBrushKey,
                                                            Converter={StaticResource BrushKeyConverter}}">
                                                    <TextBlock Text="{Binding ChainStatus.StatusPillLabel}" />
                                                </Border>
                                                <TextBlock Text="{Binding ChainStatus.ResultSummary}"
                                                           FontSize="{DynamicResource FontSizeCaption}"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding ChainStatus.HasResult}" />
                                                <TextBlock Text="·"
                                                           FontSize="{DynamicResource FontSizeCaption}"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding ChainStatus.HasResult}" />
                                                <TextBlock Text="{Binding ChainStatus.LastVerifiedAtLabel}"
                                                           FontSize="{DynamicResource FontSizeCaption}"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding LatestCheckpointLabel, StringFormat='Last checkpoint: {0}'}"
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       IsVisible="{Binding HasLatestCheckpoint}"
                                                       ToolTip.Tip="The most recent Ed25519-signed checkpoint over the audit chain. Checkpoints let verification skip re-hashing older rows and prove the chain head has not been rewritten since it was signed. Created automatically on a periodic timer." />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                                    VerticalAlignment="Center">
                                            <Button Classes="actionButton"
                                                    Content="{Binding ExportButtonLabel}"
                                                    Command="{Binding ExportChainCommand}"
                                                    IsEnabled="{Binding !IsExportingChain}"
                                                    ToolTip.Tip="Save the entire chain-audited event log as a signed JSON file. The export is signed with the daemon's Ed25519 key and embeds each row's hash, so a third party can verify both its authenticity and internal integrity." />
                                            <Button Classes="actionButton"
                                                    Content="{Binding VerifyButtonLabel}"
                                                    Command="{Binding VerifyChainCommand}"
                                                    IsEnabled="{Binding !IsVerifyingChain}"
                                                    ToolTip.Tip="Re-hash every row in the chain-audited event log and confirm the chain links are intact. Runs automatically on a periodic timer; this is the manual override." />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Open data folder row -->
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="4"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Data folder"
                                                       FontSize="{DynamicResource FontSizeBody}"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <SelectableTextBlock Text="{Binding DatabasePath}"
                                                                     FontSize="{DynamicResource FontSizeCaption}"
                                                                     Foreground="{DynamicResource TextMuted}"
                                                                     FontFamily="Cascadia Code, Consolas, monospace"
                                                                     VerticalAlignment="Center" />
                                                <Button Classes="iconButton"
                                                        Content="⎘"
                                                        Command="{Binding CopyToClipboardCommand}"
                                                        CommandParameter="{Binding DatabasePath}"
                                                        ToolTip.Tip="Copy path to clipboard" />
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Classes="actionButton"
                                                Content="OPEN FOLDER"
                                                Command="{Binding OpenDataFolderCommand}"
                                                IsEnabled="{Binding HasOpenableDataFolder}"
                                                ToolTip.Tip="Open the file explorer at the directory containing the daemon's SQLite database file." />
                                    </Grid>

                                    <controls:ErrorBanner Severity="Warn"
                                                          Message="{Binding VerifyStatusMessage}"
                                                          IsVisible="{Binding HasVerifyStatus}"
                                                          DismissCommand="{Binding DismissVerifyStatusCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ──────────  ABOUT  ────────── -->
                        <Border x:Name="AboutCard" Classes="sectionCard">
                            <Grid>
                                <Border Classes="accentStripe neutral" />
                                <StackPanel Orientation="Vertical" Spacing="16">
                                    <TextBlock Classes="sectionTitle" Text="ABOUT" />

                                    <!-- Brand block: ASCII eye on left, project identity on right -->
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="24">
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Static vm:AboutInfo.AsciiEyeArt}"
                                                   FontFamily="Cascadia Code, Consolas, monospace"
                                                   FontSize="{DynamicResource FontSizeBody}"
                                                   Foreground="{DynamicResource AccentPrimary}"
                                                   LineHeight="14"
                                                   VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="4"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AboutInfo.ProjectName}"
                                                       FontSize="{DynamicResource FontSizeHeading}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <SelectableTextBlock Text="{Binding AboutInfo.Version, StringFormat='v{0}'}"
                                                                     FontSize="{DynamicResource FontSizeBody}"
                                                                     Foreground="{DynamicResource TextSecondary}"
                                                                     FontFamily="Cascadia Code, Consolas, monospace" />
                                                <TextBlock Text="·"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           Foreground="{DynamicResource TextMuted}" />
                                                <TextBlock Text="{Binding AboutInfo.LicenseLabel}"
                                                           FontSize="{DynamicResource FontSizeBody}"
                                                           Foreground="{DynamicResource TextSecondary}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding AboutInfo.BuildInfo}"
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontFamily="Cascadia Code, Consolas, monospace" />
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                                <Button Classes="link"
                                                        Content="{Binding AboutInfo.ProjectUrl}"
                                                        Command="{Binding OpenUrlCommand}"
                                                        CommandParameter="{Binding AboutInfo.ProjectUrl}"
                                                        FontSize="{DynamicResource FontSizeCaption}" />
                                                <Button Classes="iconButton"
                                                        Content="⎘"
                                                        Command="{Binding CopyToClipboardCommand}"
                                                        CommandParameter="{Binding AboutInfo.ProjectUrl}"
                                                        ToolTip.Tip="Copy URL to clipboard" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding WatchingSinceLabel,
                                                StringFormat='Watching this machine {0}'}"
                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       IsVisible="{Binding WatchingSinceLabel, Converter={StaticResource StringEqualsConverter}, ConverterParameter=__non_empty__, FallbackValue=False}"
                                                       Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Attributions -->
                                    <StackPanel Orientation="Vertical" Spacing="8" Margin="0,12,0,0">
                                        <TextBlock Classes="fieldLabel" Text="ATTRIBUTIONS" />
                                        <ItemsControl ItemsSource="{Binding AboutInfo.Attributions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:Attribution">
                                                    <StackPanel Orientation="Vertical" Spacing="2" Margin="0,4">
                                                        <TextBlock Text="{Binding Label}"
                                                                   FontSize="{DynamicResource FontSizeBody}"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   TextWrapping="Wrap" />
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding LicenseLabel}"
                                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                                       Foreground="{DynamicResource TextMuted}"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Text="·"
                                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                                       Foreground="{DynamicResource TextMuted}"
                                                                       VerticalAlignment="Center" />
                                                            <Button Classes="link"
                                                                    Content="{Binding Url}"
                                                                    Command="{Binding $parent[UserControl].((vm:SettingsTabViewModel)DataContext).OpenUrlCommand}"
                                                                    CommandParameter="{Binding Url}"
                                                                    FontSize="{DynamicResource FontSizeCaption}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
