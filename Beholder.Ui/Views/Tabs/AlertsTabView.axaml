<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Beholder.Ui.ViewModels"
             x:Class="Beholder.Ui.Views.Tabs.AlertsTabView"
             x:DataType="vm:AlertsTabViewModel"
             Background="{DynamicResource BackgroundRoot}">

    <UserControl.Styles>
        <!-- Master ListBox row container — selection + hover states. -->
        <Style Selector="ListBox.alertList">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ListBox.alertList ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="ListBox.alertList ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
        </Style>
        <Style Selector="ListBox.alertList ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundSelected}" />
        </Style>

        <!-- Kind badge: small uppercase label tinted by AlertKind. -->
        <Style Selector="Border.kindBadge">
            <Setter Property="Padding" Value="6,2" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Border.kindBadge.info">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.kindBadge.warn">
            <Setter Property="BorderBrush" Value="{DynamicResource SeverityWarn}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.kindBadge.danger">
            <Setter Property="BorderBrush" Value="{DynamicResource SeverityDanger}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.kindBadge.muted">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Border.kindBadge TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="LetterSpacing" Value="1" />
        </Style>
        <Style Selector="Border.kindBadge.info TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}" />
        </Style>
        <Style Selector="Border.kindBadge.warn TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SeverityWarn}" />
        </Style>
        <Style Selector="Border.kindBadge.danger TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SeverityDanger}" />
        </Style>
        <Style Selector="Border.kindBadge.muted TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>

        <!-- Field label in the detail pane. -->
        <Style Selector="TextBlock.fieldLabel">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="LetterSpacing" Value="2" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>

        <!-- Action buttons. Mirrors the toolbarPill discipline from the
             Firewall tab (caps, narrow padding, fixed width to absorb text
             changes per UI_QUALITY_STANDARDS §2.5). -->
        <Style Selector="Button.actionButton">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
        </Style>
        <Style Selector="Button.actionButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
        </Style>
        <Style Selector="Button.actionButton.danger">
            <Setter Property="Foreground" Value="{DynamicResource SeverityDanger}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SeverityDanger}" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="320,*">

        <!-- ────────────────  Master pane: alert list  ──────────────── -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header strip: ALERTS label + unread/total counts. -->
                <Border DockPanel.Dock="Top"
                        Background="{DynamicResource BackgroundPanel}"
                        BorderBrush="{DynamicResource DividerHorizontal}"
                        BorderThickness="0,0,0,1"
                        Padding="16,12">
                    <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                        <TextBlock Text="ALERTS"
                                   FontSize="{DynamicResource FontSizeCaption}"
                                   LetterSpacing="2"
                                   Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center" />
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="{DynamicResource FontSizeBody}">
                            <Run Text="·" Foreground="{DynamicResource TextMuted}" />
                            <Run Text="{Binding UnreadCount}" Foreground="{DynamicResource TextPrimary}" />
                            <Run Text=" UNREAD" Foreground="{DynamicResource TextMuted}" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Master list. -->
                <ListBox Classes="alertList"
                         ItemsSource="{Binding Alerts}"
                         SelectedItem="{Binding SelectedAlert, Mode=TwoWay}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:AlertRow">
                            <!-- Two-row vertical layout: badge + timestamp on top,
                                 process name on bottom. Process name uses
                                 CharacterEllipsis so long names (e.g. com.docker.backend.exe)
                                 truncate cleanly inside the 320px master column instead
                                 of overdrawing the timestamp. -->
                            <Grid ColumnDefinitions="3,*" Margin="12,8" ColumnSpacing="10">
                                <Rectangle Grid.Column="0"
                                           Width="3"
                                           Fill="{DynamicResource AccentPrimary}"
                                           IsVisible="{Binding !IsRead}" />
                                <Grid Grid.Column="1"
                                      RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="Auto,*,Auto"
                                      RowSpacing="4"
                                      ColumnSpacing="8">
                                    <!-- Top row: kind badge (left) + timestamp (right).
                                         Empty middle column flexes to absorb extra width. -->
                                    <Border Grid.Row="0" Grid.Column="0"
                                            Classes="kindBadge"
                                            Classes.info="{Binding KindBadgeClass, Converter={StaticResource StringEqualsConverter}, ConverterParameter=info}"
                                            Classes.warn="{Binding KindBadgeClass, Converter={StaticResource StringEqualsConverter}, ConverterParameter=warn}"
                                            Classes.danger="{Binding KindBadgeClass, Converter={StaticResource StringEqualsConverter}, ConverterParameter=danger}"
                                            Classes.muted="{Binding KindBadgeClass, Converter={StaticResource StringEqualsConverter}, ConverterParameter=muted}">
                                        <TextBlock Text="{Binding KindLabel}" />
                                    </Border>
                                    <TextBlock Grid.Row="0" Grid.Column="2"
                                               Text="{Binding TimestampLabel}"
                                               FontSize="{DynamicResource FontSizeCaption}"
                                               Foreground="{DynamicResource TextMuted}"
                                               VerticalAlignment="Center" />
                                    <!-- Bottom row: process name spans all three
                                         columns. Body-size (not Subheading) since the
                                         row has its own line now and Subheading would
                                         make the row uncomfortably tall. -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                               Text="{Binding DisplayName}"
                                               FontSize="{DynamicResource FontSizeBody}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ────────────────  Detail pane (populated)  ──────────────── -->
        <Grid Grid.Column="1"
              IsVisible="{Binding ShowDetailPane}"
              RowDefinitions="Auto,*,Auto"
              Margin="24">

            <!-- Header: kind badge + full timestamp. -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="14" Margin="0,0,0,20">
                <Border Classes="kindBadge"
                        Classes.info="{Binding SelectedAlert.KindBadgeClass, Converter={StaticResource StringEqualsConverter}, ConverterParameter=info}"
                        Classes.warn="{Binding SelectedAlert.KindBadgeClass, Converter={StaticResource StringEqualsConverter}, ConverterParameter=warn}"
                        Classes.danger="{Binding SelectedAlert.KindBadgeClass, Converter={StaticResource StringEqualsConverter}, ConverterParameter=danger}"
                        Classes.muted="{Binding SelectedAlert.KindBadgeClass, Converter={StaticResource StringEqualsConverter}, ConverterParameter=muted}">
                    <TextBlock Text="{Binding SelectedAlert.KindLabel}" />
                </Border>
                <TextBlock Text="{Binding SelectedAlert.Timestamp, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                           FontSize="{DynamicResource FontSizeBody}"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Body: process path + summary. -->
            <StackPanel Grid.Row="1" Spacing="6">
                <TextBlock Classes="fieldLabel" Text="PROCESS" />
                <SelectableTextBlock Text="{Binding SelectedAlert.ProcessPath}"
                                     FontSize="{DynamicResource FontSizeBody}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     Margin="0,0,0,16" />
                <TextBlock Classes="fieldLabel" Text="DETAILS" />
                <SelectableTextBlock Text="{Binding SelectedAlert.Summary}"
                                     FontSize="{DynamicResource FontSizeBody}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     TextWrapping="Wrap" />
            </StackPanel>

            <!-- Footer: action buttons. -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Classes="actionButton"
                        Content="ADD RULE"
                        Command="{Binding AddRuleCommand}"
                        CommandParameter="{Binding SelectedAlert}"
                        ToolTip.Tip="Switch to the Firewall tab and highlight the rule for this process." />
                <!-- BLOCK / UNBLOCK toggle: two buttons sharing the actionButton
                     MinWidth=120, exactly one visible at a time via IsVisible.
                     IsOutboundBlocked is owned by the VM's _outboundBlockedPaths
                     cache, seeded from snapshot.FirewallRules at activation and
                     kept in sync via the daemon's RuleChange broadcast. Both
                     fixed-width so the footer doesn't reflow when state flips. -->
                <Button Classes="actionButton danger"
                        Content="BLOCK PROCESS OUT"
                        Command="{Binding BlockProcessOutCommand}"
                        CommandParameter="{Binding SelectedAlert}"
                        IsVisible="{Binding !SelectedAlert.IsOutboundBlocked}"
                        ToolTip.Tip="Add a Block-outbound firewall rule for this process and apply it now." />
                <Button Classes="actionButton"
                        Content="UNBLOCK PROCESS OUT"
                        Command="{Binding UnblockProcessOutCommand}"
                        CommandParameter="{Binding SelectedAlert}"
                        IsVisible="{Binding SelectedAlert.IsOutboundBlocked}"
                        ToolTip.Tip="Remove the existing Block-outbound firewall rule for this process." />
            </StackPanel>
        </Grid>

        <!-- ────────────────  Empty state  ──────────────── -->
        <StackPanel Grid.Column="1"
                    IsVisible="{Binding ShowEmptyState}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="6"
                    Margin="32">
            <TextBlock Text="No alerts to display"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="{DynamicResource FontSizeHeading}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Alerts appear when a binary makes its first network connection, when a tracked binary's hash changes, or when chain integrity verification finds a problem."
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="{DynamicResource FontSizeBody}"
                       MaxWidth="420"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
        </StackPanel>

        <!-- ────────────────  Loading state  ──────────────── -->
        <Panel Grid.Column="1" IsVisible="{Binding ShowLoadingState}">
            <TextBlock Text="Loading alerts..."
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="{DynamicResource FontSizeHeading}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Panel>

        <!-- ────────────────  Error banner  ──────────────── -->
        <Border Grid.Column="1"
                IsVisible="{Binding HasError}"
                VerticalAlignment="Top"
                Background="{DynamicResource BackgroundElevated}"
                BorderBrush="{DynamicResource SeverityDanger}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource SeverityDanger}"
                       FontSize="{DynamicResource FontSizeBody}" />
        </Border>
    </Grid>
</UserControl>
