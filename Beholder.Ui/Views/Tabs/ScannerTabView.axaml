<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Beholder.Ui.ViewModels"
             x:Class="Beholder.Ui.Views.Tabs.ScannerTabView"
             x:DataType="vm:ScannerTabViewModel"
             Background="{DynamicResource BackgroundRoot}">
    <TextBlock Text="Scanner tab content (deferred)"
               Foreground="{DynamicResource TextMuted}"
               FontSize="{DynamicResource FontSizeHeading}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
</UserControl>
