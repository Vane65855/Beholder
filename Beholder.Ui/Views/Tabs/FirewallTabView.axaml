<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Beholder.Ui.ViewModels"
             xmlns:controls="using:Beholder.Ui.Controls"
             xmlns:tabs="using:Beholder.Ui.Views.Tabs"
             x:Class="Beholder.Ui.Views.Tabs.FirewallTabView"
             x:DataType="vm:FirewallTabViewModel"
             Background="{DynamicResource BackgroundRoot}">

    <UserControl.Styles>
        <!-- Header bar pill style — same shape as Traffic tab's toolbar
             pills so the visual rhythm carries across tabs. -->
        <Style Selector="Button.toolbarPill">
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>
        <Style Selector="Button.toolbarPill.active">
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}" />
        </Style>
        <Style Selector="Button.toolbarPill.danger">
            <Setter Property="Foreground" Value="{DynamicResource SeverityDanger}" />
            <Setter Property="BorderBrush" Value="{DynamicResource SeverityDanger}" />
        </Style>
        <Style Selector="Button.toolbarPill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
        </Style>

        <!-- Group header style — collapsible Active/Inactive section dividers.
             Wrapped in a borderless Button so the whole strip is a click target. -->
        <Style Selector="Border.groupHeader">
            <Setter Property="Background" Value="{DynamicResource BackgroundPanel}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerHorizontal}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="16,8" />
        </Style>
        <Style Selector="Button.groupHeaderButton">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.groupHeaderButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
        </Style>

        <Style Selector="TextBlock.colHeader">
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="LetterSpacing" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Border.ruleRow">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerHorizontal}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style Selector="Border.ruleRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
        </Style>
    </UserControl.Styles>

    <DockPanel>

        <!-- ── Activity strip (Phase 6.5) — docked at the bottom so it
             survives resize without overlapping the rule table.        -->
        <tabs:FirewallActivityStrip DockPanel.Dock="Bottom"
                                    DataContext="{Binding ActivityVm}" />

        <!-- ── Header bar ────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BackgroundPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <!-- Counts -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14"
                            VerticalAlignment="Center">
                    <TextBlock Text="RULES"
                               FontSize="{DynamicResource FontSizeCaption}"
                               LetterSpacing="2"
                               Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" />
                    <TextBlock VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeBody}"
                               Foreground="{DynamicResource TextSecondary}">
                        <Run Text="·" Foreground="{DynamicResource TextMuted}" />
                        <Run Text="{Binding TotalProcessCount}" Foreground="{DynamicResource TextPrimary}" />
                        <Run Text=" PROCESSES" Foreground="{DynamicResource TextMuted}" />
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeBody}">
                        <Run Text="·" Foreground="{DynamicResource TextMuted}" />
                        <!-- Foreground via CountToSeverityBrushConverter: muted when zero,
                             SeverityDanger when > 0. Avoids the alarming look when zero
                             rules are blocked (the most common state on tab open). -->
                        <Run Text="{Binding BlockedProcessCount}"
                             Foreground="{Binding BlockedProcessCount, Converter={StaticResource CountToSeverityBrushConverter}, ConverterParameter=SeverityDanger}" />
                        <Run Text=" BLOCKED" Foreground="{DynamicResource TextMuted}" />
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center"
                               FontSize="{DynamicResource FontSizeBody}">
                        <Run Text="·" Foreground="{DynamicResource TextMuted}" />
                        <Run Text="{Binding PartialProcessCount}"
                             Foreground="{Binding PartialProcessCount, Converter={StaticResource CountToSeverityBrushConverter}, ConverterParameter=SeverityWarn}" />
                        <Run Text=" PARTIAL" Foreground="{DynamicResource TextMuted}" />
                    </TextBlock>
                </StackPanel>

                <!-- Search -->
                <TextBox Grid.Column="1"
                         Text="{Binding SearchText, Mode=TwoWay}"
                         PlaceholderText="search process or path"
                         Width="200"
                         FontSize="{DynamicResource FontSizeBody}"
                         Background="{DynamicResource BackgroundElevated}"
                         BorderBrush="{DynamicResource BorderSubtle}"
                         CornerRadius="3"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center" />

                <!-- Filter dropdown -->
                <ComboBox Grid.Column="2"
                          SelectedIndex="{Binding SelectedFilter, Mode=TwoWay, Converter={StaticResource EnumToIntConverter}}"
                          Width="140"
                          FontSize="{DynamicResource FontSizeBody}"
                          Background="{DynamicResource BackgroundElevated}"
                          BorderBrush="{DynamicResource BorderSubtle}"
                          Margin="0,0,12,0"
                          VerticalAlignment="Center">
                    <ComboBoxItem Content="ALL" />
                    <ComboBoxItem Content="ACTIVE ONLY" />
                    <ComboBoxItem Content="INACTIVE ONLY" />
                    <ComboBoxItem Content="BLOCKED" />
                    <ComboBoxItem Content="PARTIAL" />
                </ComboBox>

                <!-- Master ON/OFF toggle -->
                <Button Grid.Column="3"
                        Classes="toolbarPill"
                        Classes.active="{Binding IsFirewallEnabled}"
                        Classes.danger="{Binding !IsFirewallEnabled}"
                        Command="{Binding ToggleEnforcementCommand}"
                        ToolTip.Tip="Click to disable. Rules stay saved in Beholder, but stop applying to Windows Firewall — apps regain network access until re-enabled."
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="FIREWALL:" />
                        <TextBlock Text="ON" IsVisible="{Binding IsFirewallEnabled}" FontWeight="SemiBold" />
                        <TextBlock Text="OFF" IsVisible="{Binding !IsFirewallEnabled}" FontWeight="SemiBold" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── Enforcement-disabled banner ──────────────────────────── -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding !IsFirewallEnabled}"
                Background="{DynamicResource BackgroundElevated}"
                BorderBrush="{DynamicResource SeverityWarn}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <TextBlock Text="Firewall enforcement is disabled. Rule changes are saved but not applied to Windows Firewall."
                       Foreground="{DynamicResource SeverityWarn}"
                       FontSize="{DynamicResource FontSizeBody}" />
        </Border>

        <!-- ── Error banner ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding HasError}"
                Background="{DynamicResource BackgroundElevated}"
                BorderBrush="{DynamicResource SeverityDanger}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource SeverityDanger}"
                       FontSize="{DynamicResource FontSizeBody}" />
        </Border>

        <!-- ── Loading overlay ──────────────────────────────────────── -->
        <Panel IsVisible="{Binding IsLoading}">
            <TextBlock Text="Loading firewall rules..."
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="{DynamicResource FontSizeHeading}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Panel>

        <!-- ── Empty state ──────────────────────────────────────────── -->
        <StackPanel IsVisible="{Binding !HasRows}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="6"
                    Margin="32">
            <TextBlock Text="No processes have been seen yet"
                       Foreground="{DynamicResource TextSecondary}"
                       FontSize="{DynamicResource FontSizeHeading}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="As applications make connections, they'll appear here. Click any pill to block an app's traffic — apps default to allowed unless you block them."
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="{DynamicResource FontSizeBody}"
                       MaxWidth="420"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
        </StackPanel>

        <!-- ── Rule table ───────────────────────────────────────────── -->
        <ScrollViewer IsVisible="{Binding HasRows}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Column header row. Pill columns are fixed-width (56) to match
                     FirewallActionPill's MinWidth, so headers align dead-centre
                     above the pills below. PROCESS takes the remaining space; the
                     three trailing columns are fixed for legibility. -->
                <Border Background="{DynamicResource BackgroundPanel}"
                        BorderBrush="{DynamicResource DividerHorizontal}"
                        BorderThickness="0,0,0,1"
                        Padding="16,8">
                    <Grid ColumnDefinitions="*,56,56,140,90,80">
                        <TextBlock Grid.Column="0" Classes="colHeader" Text="PROCESS" />
                        <TextBlock Grid.Column="1" Classes="colHeader" Text="IN"
                                   HorizontalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="2" Classes="colHeader" Text="OUT"
                                   HorizontalAlignment="Center" Margin="0,0,12,0" />
                        <TextBlock Grid.Column="3" Classes="colHeader" Text="HOSTS" />
                        <TextBlock Grid.Column="4" Classes="colHeader" Text="RECENT" />
                        <TextBlock Grid.Column="5" Classes="colHeader" Text="SOURCE" />
                    </Grid>
                </Border>

                <!-- ACTIVE APPS group — clickable header toggles expansion. -->
                <Button Classes="groupHeaderButton"
                        IsVisible="{Binding HasFilteredActiveRows}"
                        Command="{Binding ToggleActiveExpandedCommand}">
                    <Border Classes="groupHeader">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="▾" IsVisible="{Binding IsActiveExpanded}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="▸" IsVisible="{Binding !IsActiveExpanded}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="ACTIVE APPS"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="{DynamicResource FontSizeCaption}"
                                       LetterSpacing="2"
                                       VerticalAlignment="Center" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="{DynamicResource FontSizeCaption}"
                                       Foreground="{DynamicResource TextMuted}">
                                <Run Text="·" />
                                <Run Text="{Binding ActiveRows.Count}" Foreground="{DynamicResource TextPrimary}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Button>

                <ItemsControl ItemsSource="{Binding FilteredActiveRows}"
                              IsVisible="{Binding IsActiveExpanded}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FirewallRuleRow">
                            <Border Classes="ruleRow">
                                <Grid ColumnDefinitions="*,56,56,140,90,80">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                Spacing="10" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8"
                                                 VerticalAlignment="Center"
                                                 Fill="{DynamicResource AccentPrimary}" />
                                        <StackPanel Orientation="Vertical" Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       FontSize="{DynamicResource FontSizeSubheading}" />
                                            <TextBlock Text="{Binding ProcessPath}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="{DynamicResource FontSizeSmall}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="420"
                                                       ToolTip.Tip="{Binding ProcessPath}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <controls:FirewallActionPill
                                        Grid.Column="1"
                                        State="{Binding InAction}"
                                        Command="{Binding $parent[ItemsControl].((vm:FirewallTabViewModel)DataContext).CycleInPillCommand}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                                    <controls:FirewallActionPill
                                        Grid.Column="2"
                                        State="{Binding OutAction}"
                                        Command="{Binding $parent[ItemsControl].((vm:FirewallTabViewModel)DataContext).CycleOutPillCommand}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,12,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding HostsLabel}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="{DynamicResource FontSizeBody}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding RecentBytesLabel}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="{DynamicResource FontSizeBody}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding SourceLabel}"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="{DynamicResource FontSizeCaption}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- INACTIVE APPS group — collapsed by default per Phase 6.4 plan. -->
                <Button Classes="groupHeaderButton"
                        IsVisible="{Binding HasFilteredInactiveRows}"
                        Command="{Binding ToggleInactiveExpandedCommand}">
                    <Border Classes="groupHeader">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="▾" IsVisible="{Binding IsInactiveExpanded}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="▸" IsVisible="{Binding !IsInactiveExpanded}"
                                       Foreground="{DynamicResource TextSecondary}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="INACTIVE APPS"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="{DynamicResource FontSizeCaption}"
                                       LetterSpacing="2"
                                       VerticalAlignment="Center" />
                            <TextBlock VerticalAlignment="Center"
                                       FontSize="{DynamicResource FontSizeCaption}"
                                       Foreground="{DynamicResource TextMuted}">
                                <Run Text="·" />
                                <Run Text="{Binding InactiveRows.Count}" Foreground="{DynamicResource TextPrimary}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Button>

                <ItemsControl ItemsSource="{Binding FilteredInactiveRows}"
                              IsVisible="{Binding IsInactiveExpanded}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:FirewallRuleRow">
                            <!-- No row-level Opacity here: the muted dot + TextSecondary
                                 / TextMuted hierarchy already differentiates inactive
                                 rows visually, and stacking Opacity on top of muted
                                 tokens makes paths hard to read. -->
                            <Border Classes="ruleRow">
                                <Grid ColumnDefinitions="*,56,56,140,90,80">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                Spacing="10" VerticalAlignment="Center">
                                        <!-- Indicator: muted dot for normal inactive rows;
                                             ⚠ glyph (SeverityWarn amber) for orphaned-rule
                                             rows where the .exe is gone but a manual rule
                                             still references it. Tooltip on the warning
                                             glyph explains the state and the remedy. -->
                                        <Panel Width="14" Height="14" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Fill="{DynamicResource TextMuted}"
                                                     IsVisible="{Binding !IsOrphanedRule}" />
                                            <TextBlock Text="⚠"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SeverityWarn}"
                                                       IsVisible="{Binding IsOrphanedRule}"
                                                       ToolTip.Tip="App no longer installed. The firewall rule still exists — click the BLOCK pill to remove it." />
                                        </Panel>
                                        <StackPanel Orientation="Vertical" Spacing="2">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="{DynamicResource FontSizeSubheading}" />
                                            <TextBlock Text="{Binding ProcessPath}"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="{DynamicResource FontSizeSmall}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="420"
                                                       ToolTip.Tip="{Binding ProcessPath}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <controls:FirewallActionPill
                                        Grid.Column="1"
                                        State="{Binding InAction}"
                                        Command="{Binding $parent[ItemsControl].((vm:FirewallTabViewModel)DataContext).CycleInPillCommand}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                                    <controls:FirewallActionPill
                                        Grid.Column="2"
                                        State="{Binding OutAction}"
                                        Command="{Binding $parent[ItemsControl].((vm:FirewallTabViewModel)DataContext).CycleOutPillCommand}"
                                        CommandParameter="{Binding}"
                                        Margin="0,0,12,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                                    <TextBlock Grid.Column="3"
                                               Text="{Binding HostsLabel}"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="{DynamicResource FontSizeBody}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding RecentBytesLabel}"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="{DynamicResource FontSizeBody}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding SourceLabel}"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="{DynamicResource FontSizeCaption}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
