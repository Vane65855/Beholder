<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Beholder.Ui.ViewModels"
             xmlns:models="using:Beholder.Ui.Models"
             xmlns:controls="using:Beholder.Ui.Controls"
             xmlns:tabs="using:Beholder.Ui.Views.Tabs"
             x:Class="Beholder.Ui.Views.Tabs.TrafficTabView"
             x:DataType="vm:TrafficTabViewModel"
             Background="{DynamicResource BackgroundRoot}">

    <UserControl.Styles>
        <Style Selector="Button.toolbarPill">
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>
        <Style Selector="Button.toolbarPill.active">
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}" />
        </Style>
        <Style Selector="Button.toolbarPill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="280,*">

        <Border Grid.Column="0"
                Background="{DynamicResource BackgroundPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header row — columns mirror the item template for alignment -->
                <Grid DockPanel.Dock="Top"
                      ColumnDefinitions="14,*,Auto,Auto"
                      Margin="12,10,12,6">
                    <TextBlock Grid.Column="1"
                               Text="PROCESS"
                               FontSize="{DynamicResource FontSizeCaption}"
                               LetterSpacing="1"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="6,0,8,0" />
                    <TextBlock Grid.Column="2"
                               Text="IN"
                               FontSize="{DynamicResource FontSizeCaption}"
                               LetterSpacing="1"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,8,0" />
                    <TextBlock Grid.Column="3"
                               Text="OUT"
                               FontSize="{DynamicResource FontSizeCaption}"
                               LetterSpacing="1"
                               Foreground="{DynamicResource TextMuted}" />
                </Grid>

                <Border DockPanel.Dock="Top"
                        Height="1"
                        Background="{DynamicResource DividerHorizontal}"
                        Margin="0,0,0,2" />

                <!-- Process list -->
                <ListBox ItemsSource="{Binding ProcessList}"
                         SelectedItem="{Binding SelectedProcess}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12,6" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource BackgroundSelected}" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ProcessListItem">
                            <Grid ColumnDefinitions="14,*,Auto,Auto" Height="24">
                                <!-- Colored series dot -->
                                <Ellipse Grid.Column="0"
                                         Width="8" Height="8"
                                         VerticalAlignment="Center"
                                         Fill="{Binding SeriesIndex, Converter={StaticResource SeriesToBrush}}" />

                                <!-- Process name -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="{DynamicResource FontSizeSubheading}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="6,0,8,0" />

                                <!-- IN: teal arrow + recent-window bytes in.
                                     ChartOutboundStroke token is semantically the
                                     download/teal color (name is legacy — see DarkTheme.axaml). -->
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0">
                                    <TextBlock Text="▼ "
                                               FontSize="{DynamicResource FontSizeSubheading}"
                                               Foreground="{DynamicResource ChartOutboundStroke}" />
                                    <TextBlock Text="{Binding RecentInLabel}"
                                               FontSize="{DynamicResource FontSizeSubheading}"
                                               Foreground="{DynamicResource TextSecondary}" />
                                </StackPanel>

                                <!-- OUT: purple arrow + recent-window bytes out.
                                     ChartInboundStroke token is semantically the
                                     upload/purple color (name is legacy). -->
                                <StackPanel Grid.Column="3"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="▲ "
                                               FontSize="{DynamicResource FontSizeSubheading}"
                                               Foreground="{DynamicResource ChartInboundStroke}" />
                                    <TextBlock Text="{Binding RecentOutLabel}"
                                               FontSize="{DynamicResource FontSizeSubheading}"
                                               Foreground="{DynamicResource TextSecondary}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <DockPanel Grid.Column="1" Margin="0">

            <!-- Top bar: chart title + range selector + view switcher -->
            <Grid DockPanel.Dock="Top"
                  ColumnDefinitions="*,Auto,Auto"
                  Margin="16,10,16,6">
                <TextBlock Grid.Column="0"
                           Text="TRAFFIC  ·  BYTES/SEC"
                           FontSize="{DynamicResource FontSizeCaption}"
                           LetterSpacing="1"
                           Foreground="{DynamicResource TextMuted}"
                           VerticalAlignment="Center" />

                <controls:TimeRangeDropdown Grid.Column="1"
                                            SelectedRange="{Binding SelectedTimeRange, Mode=TwoWay}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,12,0" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="2">
                    <Button Content="GRAPH"
                            Classes="toolbarPill"
                            Classes.active="{Binding IsGraphActive}"
                            Command="{Binding SetGraphViewCommand}" />
                    <Button Content="COLS"
                            Classes="toolbarPill"
                            Classes.active="{Binding IsColsActive}"
                            Command="{Binding SetColsViewCommand}" />
                    <Button Content="MAP"
                            Classes="toolbarPill"
                            IsEnabled="False"
                            ToolTip.Tip="Geographic map — coming soon" />
                </StackPanel>
            </Grid>

            <!-- Chart / COLS area. Graph and COLS views share the same
                 pane — only one renders at a time based on ViewMode. MAP is
                 deferred until Phase 8 and the pill stays disabled. -->
            <Grid>
                <!-- GRAPH view: chart + state overlays -->
                <Grid IsVisible="{Binding IsGraphActive}">
                    <controls:TrafficChartControl SeriesData="{Binding ChartData}"
                                                 DataSpan="{Binding ChartDataSpan}"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Stretch"
                                                 Margin="8,0,8,8" />

                    <!-- Loading overlay -->
                    <StackPanel IsVisible="{Binding IsLoading}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <TextBlock Text="Connecting to daemon..."
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="{DynamicResource FontSizeHeading}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Empty overlay -->
                    <StackPanel IsVisible="{Binding IsEmpty}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="4">
                        <TextBlock Text="No traffic data yet"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{DynamicResource FontSizeHeading}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Traffic will appear when processes access the network."
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="{DynamicResource FontSizeBody}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Error overlay -->
                    <Border IsVisible="{Binding HasError}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,8,0,0"
                            Padding="12,6"
                            Background="{DynamicResource BackgroundElevated}"
                            CornerRadius="4"
                            BorderBrush="{DynamicResource SeverityWarn}"
                            BorderThickness="1">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource SeverityWarn}"
                                   FontSize="{DynamicResource FontSizeBody}" />
                    </Border>
                </Grid>

                <!-- COLS view: Hosts / Traffic Type / Countries bar lists.
                     The Panel wrapper carries IsVisible against the outer
                     TrafficTabViewModel, then DataContext flips to ColsVm
                     for the child control. Two bindings on the same element
                     both using the DataContext can't resolve the context
                     mid-evaluation, so we split them across two elements. -->
                <Panel IsVisible="{Binding IsColsActive}">
                    <tabs:TrafficColsView DataContext="{Binding ColsVm}" />
                </Panel>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
