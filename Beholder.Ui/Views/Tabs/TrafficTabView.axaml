<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Beholder.Ui.ViewModels"
             xmlns:models="using:Beholder.Ui.Models"
             xmlns:controls="using:Beholder.Ui.Controls"
             xmlns:tabs="using:Beholder.Ui.Views.Tabs"
             x:Class="Beholder.Ui.Views.Tabs.TrafficTabView"
             x:DataType="vm:TrafficTabViewModel"
             Background="{DynamicResource BackgroundRoot}">

    <UserControl.Styles>
        <Style Selector="Button.toolbarPill">
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>
        <Style Selector="Button.toolbarPill.active">
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}" />
        </Style>
        <Style Selector="Button.toolbarPill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
        </Style>

        <!-- Resume button: a muted green (the theme's success/"online" color) so
             it reads clearly as the "roll the live view again" action, distinct
             from the teal accent everywhere else in the selection bar. -->
        <Style Selector="Button.resumePill">
            <Setter Property="MinWidth" Value="64" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource SeveritySuccess}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeCaption}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SeveritySuccess}" />
        </Style>
        <Style Selector="Button.resumePill:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="280,*">

        <Border Grid.Column="0"
                Background="{DynamicResource BackgroundPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Header row — columns mirror the item template for alignment -->
                <Grid DockPanel.Dock="Top"
                      ColumnDefinitions="14,*,Auto,Auto,Auto"
                      Margin="12,10,12,6">
                    <TextBlock Grid.Column="1"
                               Text="PROCESS"
                               FontSize="{DynamicResource FontSizeCaption}"
                               LetterSpacing="1"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="6,0,8,0" />
                    <TextBlock Grid.Column="3"
                               Text="IN"
                               FontSize="{DynamicResource FontSizeCaption}"
                               LetterSpacing="1"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,8,0" />
                    <TextBlock Grid.Column="4"
                               Text="OUT"
                               FontSize="{DynamicResource FontSizeCaption}"
                               LetterSpacing="1"
                               Foreground="{DynamicResource TextMuted}" />
                </Grid>

                <Border DockPanel.Dock="Top"
                        Height="1"
                        Background="{DynamicResource DividerHorizontal}"
                        Margin="0,0,0,2" />

                <!-- Process list -->
                <ListBox ItemsSource="{Binding ProcessList}"
                         SelectedItem="{Binding SelectedProcess}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ContextRequested="OnProcessListContextRequested">
                    <!-- Row context menu. Attached at ListBox level so it
                         inherits the tab VM DataContext directly (popup
                         ancestor lookups are unreliable in Avalonia — see
                         UI_QUALITY_STANDARDS §10). The code-behind
                         ContextRequested handler captures which row was
                         right-clicked and suppresses the menu for the
                         all-row / empty space. -->
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Open file location"
                                      IsEnabled="{Binding MenuTargetCanOpenLocation}"
                                      Command="{Binding OpenProcessFileLocationCommand}"
                                      ToolTip.Tip="Open the folder containing this binary with the file selected." />
                            <MenuItem Header="Copy path"
                                      Command="{Binding CopyProcessPathCommand}" />
                            <Separator />
                            <MenuItem Header="Open in Firewall"
                                      IsEnabled="{Binding MenuTargetCanOpenFirewall}"
                                      Command="{Binding OpenProcessInFirewallCommand}"
                                      ToolTip.Tip="Switch to the Firewall tab and highlight this process's rule row." />
                            <Separator />
                            <MenuItem Header="{Binding MenuTargetExcludeHeader}"
                                      Command="{Binding ToggleProcessTotalsExclusionCommand}"
                                      ToolTip.Tip="Excluded processes stay recorded and alertable — they're only removed from All-processes totals, charts, and breakdowns." />
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="12,6" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource BackgroundHover}" />
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource BackgroundSelected}" />
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ProcessListItem">
                            <Grid ColumnDefinitions="14,*,Auto,Auto,Auto" Height="24">
                                <!-- Colored series dot -->
                                <Ellipse Grid.Column="0"
                                         Width="8" Height="8"
                                         VerticalAlignment="Center"
                                         Fill="{Binding SeriesIndex, Converter={StaticResource SeriesToBrush}}" />

                                <!-- Process name -->
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="{DynamicResource FontSizeSubheading}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="6,0,8,0" />

                                <!-- "Excluded from totals" marker — rendered only
                                     when the show-excluded preference lists the
                                     row at all. -->
                                <TextBlock Grid.Column="2"
                                           Text="⊘"
                                           IsVisible="{Binding IsExcludedFromTotals}"
                                           FontSize="{DynamicResource FontSizeSubheading}"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           ToolTip.Tip="Excluded from totals — not counted in All-processes views. Manage in Settings → Traffic Totals." />

                                <!-- IN: teal arrow + recent-window bytes in.
                                     ChartOutboundStroke token is semantically the
                                     download/teal color (name is legacy — see DarkTheme.axaml). -->
                                <StackPanel Grid.Column="3"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0">
                                    <TextBlock Text="▼ "
                                               FontSize="{DynamicResource FontSizeSubheading}"
                                               Foreground="{DynamicResource ChartOutboundStroke}" />
                                    <TextBlock Text="{Binding RecentInLabel}"
                                               FontSize="{DynamicResource FontSizeSubheading}"
                                               Foreground="{DynamicResource TextSecondary}" />
                                </StackPanel>

                                <!-- OUT: purple arrow + recent-window bytes out.
                                     ChartInboundStroke token is semantically the
                                     upload/purple color (name is legacy). -->
                                <StackPanel Grid.Column="4"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="▲ "
                                               FontSize="{DynamicResource FontSizeSubheading}"
                                               Foreground="{DynamicResource ChartInboundStroke}" />
                                    <TextBlock Text="{Binding RecentOutLabel}"
                                               FontSize="{DynamicResource FontSizeSubheading}"
                                               Foreground="{DynamicResource TextSecondary}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <DockPanel Grid.Column="1" Margin="0">

            <!-- Top bar: chart title + range selector + view switcher -->
            <Grid DockPanel.Dock="Top"
                  ColumnDefinitions="Auto,*,Auto,Auto"
                  Margin="16,10,16,6">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="12"
                            VerticalAlignment="Center">
                    <TextBlock Text="TRAFFIC  ·  BYTES/SEC"
                               FontSize="{DynamicResource FontSizeCaption}"
                               LetterSpacing="1"
                               Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" />

                    <!-- Phase 9.6: Scanner → Traffic deep-link filter chip.
                         Visible only when an IP filter is active. Click the
                         × to clear the filter and restore the full
                         per-process list. -->
                    <Border IsVisible="{Binding HasRemoteAddressFilter}"
                            Background="{DynamicResource BackgroundPanel}"
                            BorderBrush="{DynamicResource AccentPrimary}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="8,3"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="FILTERED TO IP:"
                                       FontSize="{DynamicResource FontSizeCaption}"
                                       LetterSpacing="1"
                                       Foreground="{DynamicResource TextMuted}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding RemoteAddressFilter}"
                                       FontSize="{DynamicResource FontSizeCaption}"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{DynamicResource AccentPrimary}"
                                       VerticalAlignment="Center" />
                            <Button Content="×"
                                    Padding="4,0"
                                    MinWidth="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{DynamicResource TextSecondary}"
                                    Cursor="Hand"
                                    Command="{Binding ClearRemoteAddressFilterCommand}"
                                    ToolTip.Tip="Clear the IP filter and restore the full per-process list." />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <controls:TimeRangeDropdown Grid.Column="2"
                                            SelectedRange="{Binding SelectedTimeRange, Mode=TwoWay}"
                                            VerticalAlignment="Center"
                                            Margin="0,0,12,0" />

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            Spacing="2">
                    <Button Content="GRAPH"
                            Classes="toolbarPill"
                            Classes.active="{Binding IsGraphActive}"
                            Command="{Binding SetGraphViewCommand}" />
                    <Button Content="COLS"
                            Classes="toolbarPill"
                            Classes.active="{Binding IsColsActive}"
                            Command="{Binding SetColsViewCommand}" />
                    <Button Content="MAP"
                            Classes="toolbarPill"
                            Classes.active="{Binding IsMapActive}"
                            Command="{Binding SetMapViewCommand}"
                            ToolTip.Tip="Geographic heatmap — per-country byte totals" />
                </StackPanel>
            </Grid>

            <!-- GRAPH / COLS / MAP area. All three views share the same
                 pane — only one renders at a time based on ViewMode. See
                 UI_DESIGN.md §6 Traffic for the MAP sub-view spec. -->
            <Grid>
                <!-- GRAPH view: chart + state overlays -->
                <Grid IsVisible="{Binding IsGraphActive}">
                    <controls:TrafficChartControl SeriesData="{Binding ChartData}"
                                                 DataSpan="{Binding ChartDataSpan}"
                                                 Selection="{Binding ChartSelection, Mode=TwoWay}"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Stretch"
                                                 Margin="8,0,8,8" />

                    <!-- Loading overlay -->
                    <StackPanel IsVisible="{Binding IsLoading}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <TextBlock Text="Connecting to daemon..."
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="{DynamicResource FontSizeHeading}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Empty overlay -->
                    <StackPanel IsVisible="{Binding IsEmpty}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="4">
                        <TextBlock Text="No traffic data yet"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{DynamicResource FontSizeHeading}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Traffic will appear when processes access the network."
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="{DynamicResource FontSizeBody}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Error overlay — see UI_DESIGN.md §5.10. Severity=Warn
                         gives the centered yellow rounded-border treatment. -->
                    <controls:ErrorBanner VerticalAlignment="Top"
                                          Margin="0,8,0,0"
                                          Severity="Warn"
                                          Message="{Binding ErrorMessage}"
                                          IsVisible="{Binding HasError}"
                                          DismissCommand="{Binding DismissErrorCommand}" />

                    <!-- Selection bar — appears at the top of the chart when a
                         range is selected (which pauses the live view). The
                         header stays visible; hovering anywhere on the bar
                         reveals the full scrollable destinations list. The
                         self-referential #SelectionOverlay.IsPointerOver keeps
                         the expand open while the pointer is over the header OR
                         the list (in-tree, no popup — see UI_QUALITY_STANDARDS §10). -->
                    <Border x:Name="SelectionOverlay"
                            IsVisible="{Binding IsSelectionActive}"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Stretch"
                            Margin="8,0,8,0"
                            Background="{DynamicResource BackgroundPanel}"
                            BorderBrush="{DynamicResource AccentPrimary}"
                            BorderThickness="1"
                            CornerRadius="0,0,4,4">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top"
                                  ColumnDefinitions="Auto,Auto,*,Auto"
                                  Margin="10,5">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding SelectionAppLabel}"
                                           FontWeight="SemiBold"
                                           FontSize="{DynamicResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="220"
                                           Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SelectionWindowLabel}"
                                           FontSize="{DynamicResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SelectionDestinations.Count, StringFormat='{}{0} destinations  ·  hover to expand'}"
                                           FontSize="{DynamicResource FontSizeCaption}"
                                           Foreground="{DynamicResource TextMuted}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="12,0" />
                                <Button Grid.Column="3"
                                        Content="▶ Resume"
                                        Classes="resumePill"
                                        Command="{Binding ResumeCommand}"
                                        ToolTip.Tip="Resume live monitoring and clear the selection." />
                            </Grid>

                            <Grid IsVisible="{Binding #SelectionOverlay.IsPointerOver}"
                                  MinHeight="80"
                                  MaxHeight="320">
                                <Border BorderBrush="{DynamicResource DividerHorizontal}"
                                        BorderThickness="0,1,0,0">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  IsVisible="{Binding !SelectionLoading}">
                                        <ItemsControl ItemsSource="{Binding SelectionDestinations}"
                                                      Margin="10,6">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <VirtualizingStackPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:SelectionDestinationRow">
                                                    <Grid Height="24" Margin="0,0,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" MinWidth="88" />
                                                            <ColumnDefinition Width="Auto" MinWidth="88" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0"
                                                                    Orientation="Horizontal"
                                                                    Spacing="8"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="{DynamicResource TextPrimary}"
                                                                       FontSize="{DynamicResource FontSizeBody}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding RemoteAddress}"
                                                                       IsVisible="{Binding ShowAddress}"
                                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                                       FontSize="{DynamicResource FontSizeCaption}"
                                                                       Foreground="{DynamicResource TextMuted}"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <!-- Per-direction average speeds in the app-wide
                                                             traffic colors: the arrow glyph carries the
                                                             semantics (▼ teal download / ▲ purple upload,
                                                             the process-list idiom), the number stays
                                                             neutral. ChartOutbound/InboundStroke token
                                                             names are legacy — see DarkTheme.axaml. -->
                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,16,0"
                                                                    ToolTip.Tip="Average download speed over the selected window.">
                                                            <TextBlock Text="▼ "
                                                                       FontSize="{DynamicResource FontSizeBody}"
                                                                       Foreground="{DynamicResource ChartOutboundStroke}" />
                                                            <TextBlock Text="{Binding DownSpeedLabel}"
                                                                       FontSize="{DynamicResource FontSizeBody}"
                                                                       Foreground="{DynamicResource TextSecondary}" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2"
                                                                    Orientation="Horizontal"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,16,0"
                                                                    ToolTip.Tip="Average upload speed over the selected window.">
                                                            <TextBlock Text="▲ "
                                                                       FontSize="{DynamicResource FontSizeBody}"
                                                                       Foreground="{DynamicResource ChartInboundStroke}" />
                                                            <TextBlock Text="{Binding UpSpeedLabel}"
                                                                       FontSize="{DynamicResource FontSizeBody}"
                                                                       Foreground="{DynamicResource TextSecondary}" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="3"
                                                                   Text="{Binding BytesLabel}"
                                                                   Foreground="{DynamicResource TextSecondary}"
                                                                   FontSize="{DynamicResource FontSizeBody}"
                                                                   VerticalAlignment="Center"
                                                                   MinWidth="70"
                                                                   TextAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>

                                <TextBlock Text="Loading destinations…"
                                           IsVisible="{Binding SelectionLoading}"
                                           Foreground="{DynamicResource TextMuted}"
                                           FontSize="{DynamicResource FontSizeBody}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />

                                <StackPanel IsVisible="{Binding SelectionEmpty}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="2">
                                    <TextBlock Text="No destinations in this window"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="{DynamicResource FontSizeBody}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="The selected app reached no resolvable host in this range."
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="{DynamicResource FontSizeCaption}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>

                                <TextBlock Text="Destinations unavailable."
                                           IsVisible="{Binding SelectionFailed}"
                                           Foreground="{DynamicResource TextMuted}"
                                           FontSize="{DynamicResource FontSizeBody}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- COLS view: Hosts / Traffic Type / Countries bar lists.
                     The Panel wrapper carries IsVisible against the outer
                     TrafficTabViewModel, then DataContext flips to ColsVm
                     for the child control. Two bindings on the same element
                     both using the DataContext can't resolve the context
                     mid-evaluation, so we split them across two elements. -->
                <Panel IsVisible="{Binding IsColsActive}">
                    <tabs:TrafficColsView DataContext="{Binding ColsVm}" />
                </Panel>

                <!-- MAP view: world heatmap of per-country traffic. Heatmap
                     fills 5 stops from HeatmapCold → HeatmapPeak; LAN
                     (alpha2 dashdash) and Unknown (alpha2 question marks)
                     get the caption strip since they have no geographic
                     location. See UI_DESIGN.md §5.11 + §6 Traffic→Map. -->
                <Grid IsVisible="{Binding IsMapActive}">
                    <DockPanel>
                        <controls:ErrorBanner DockPanel.Dock="Top"
                                              Margin="0,8,0,0"
                                              Severity="Danger"
                                              Message="{Binding ErrorMessage}"
                                              IsVisible="{Binding HasError}"
                                              DismissCommand="{Binding DismissErrorCommand}" />
                        <TextBlock DockPanel.Dock="Bottom"
                                   Text="{Binding LocalAndUnknownCaption}"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="{DynamicResource FontSizeCaption}"
                                   Margin="12,4" />
                        <controls:WorldMapControl Countries="{Binding MapCountries}"
                                                  MaxBytes="{Binding MaxMapBytes}"
                                                  HoveredCountry="{Binding HoveredCountry, Mode=OneWayToSource}"
                                                  HoveredCountryDestinations="{Binding HoveredCountryDestinations}"
                                                  HoveredCountryDestinationsLoading="{Binding HoveredCountryDestinationsLoading}"
                                                  HoveredCountryDestinationsEmpty="{Binding HoveredCountryDestinationsEmpty}"
                                                  HoveredCountryDestinationsFailed="{Binding HoveredCountryDestinationsFailed}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"
                                                  Margin="8,0,8,0" />
                    </DockPanel>
                </Grid>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
