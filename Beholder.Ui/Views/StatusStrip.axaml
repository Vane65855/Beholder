<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Beholder.Ui.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="28"
             x:Class="Beholder.Ui.Views.StatusStrip"
             x:DataType="vm:StatusStripViewModel"
             Background="{DynamicResource BackgroundPanel}">

    <Border BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="0,1,0,0">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="16,4">

            <!-- OUT metrics -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Spacing="4">
                <TextBlock Text="▲"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="10"
                           VerticalAlignment="Center" />
                <TextBlock Text="OUT"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="11" FontWeight="Medium"
                           LetterSpacing="1"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding OutboundTotalLabel}"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="11"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding OutboundRateLabel}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="11"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- IN metrics -->
            <StackPanel Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center" Spacing="4"
                        Margin="16,0,0,0">
                <TextBlock Text="▼"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="10"
                           VerticalAlignment="Center" />
                <TextBlock Text="IN"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="11" FontWeight="Medium"
                           LetterSpacing="1"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding InboundTotalLabel}"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="11"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding InboundRateLabel}"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="11"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- WAN sparkline + total -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="24,0"
                        HorizontalAlignment="Right">
                <TextBlock Text="WAN"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="11" FontWeight="Medium"
                           LetterSpacing="1"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <Canvas Width="200" Height="14"
                        VerticalAlignment="Center">
                    <Polyline Points="{Binding WanSparklinePoints}"
                              Stroke="{DynamicResource ChartSparklineStroke}"
                              StrokeThickness="1.5" />
                </Canvas>
                <TextBlock Text="{Binding WanTotalLabel}"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </StackPanel>

            <!-- Device ID -->
            <StackPanel Grid.Column="3" Orientation="Horizontal"
                        VerticalAlignment="Center" Spacing="4">
                <TextBlock Text="DEV"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="11" FontWeight="Medium"
                           LetterSpacing="1"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding DeviceIdLabel}"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="11"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
