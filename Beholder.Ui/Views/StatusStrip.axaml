<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Beholder.Ui.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="28"
             x:Class="Beholder.Ui.Views.StatusStrip"
             x:DataType="vm:StatusStripViewModel"
             Background="{DynamicResource BackgroundPanel}">

    <Border BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="0,1,0,0">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="16,4">

            <!-- Download metrics -->
            <TextBlock Grid.Column="0" FontSize="11" VerticalAlignment="Center"
                       ToolTip.Tip="Download traffic. Σ = total bytes received since daemon started. Rate = bytes received in the last second.">
                <Run Text="▼ " Foreground="{DynamicResource ChartOutboundStroke}" />
                <Run Text="DOWNLOAD " Foreground="{DynamicResource TextMuted}" FontWeight="Medium" />
                <Run Text="Σ " Foreground="{DynamicResource TextMuted}" />
                <Run Text="{Binding InboundTotalLabel}" Foreground="{DynamicResource TextPrimary}" FontWeight="Medium" />
                <Run Text=" · " Foreground="{DynamicResource TextMuted}" />
                <Run Text="{Binding InboundRateLabel}" Foreground="{DynamicResource TextMuted}" />
            </TextBlock>

            <!-- Upload metrics -->
            <TextBlock Grid.Column="1" FontSize="11" VerticalAlignment="Center"
                       Margin="24,0,0,0"
                       ToolTip.Tip="Upload traffic. Σ = total bytes sent since daemon started. Rate = bytes sent in the last second.">
                <Run Text="▲ " Foreground="{DynamicResource ChartInboundStroke}" />
                <Run Text="UPLOAD " Foreground="{DynamicResource TextMuted}" FontWeight="Medium" />
                <Run Text="Σ " Foreground="{DynamicResource TextMuted}" />
                <Run Text="{Binding OutboundTotalLabel}" Foreground="{DynamicResource TextPrimary}" FontWeight="Medium" />
                <Run Text=" · " Foreground="{DynamicResource TextMuted}" />
                <Run Text="{Binding OutboundRateLabel}" Foreground="{DynamicResource TextMuted}" />
            </TextBlock>

            <!-- Ratio bar (flex-sized in star column) -->
            <Border Grid.Column="2"
                    Height="10" CornerRadius="3"
                    Background="{DynamicResource BackgroundElevated}"
                    ClipToBounds="True"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    Margin="24,0"
                    MinWidth="100"
                    ToolTip.Tip="Download/upload ratio. Teal = download share, purple = upload share.">
                <Grid IsVisible="{Binding HasTraffic}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding InboundRatio, Converter={StaticResource RatioToGridLength}}" />
                        <ColumnDefinition Width="{Binding OutboundRatio, Converter={StaticResource RatioToGridLength}}" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Fill="{DynamicResource ChartOutboundStroke}" />
                    <Rectangle Grid.Column="1" Fill="{DynamicResource ChartInboundStroke}" />
                </Grid>
            </Border>

            <!-- WAN label + total -->
            <TextBlock Grid.Column="3" FontSize="11" VerticalAlignment="Center">
                <Run Text="WAN " Foreground="{DynamicResource TextMuted}"
                     FontWeight="Medium" />
                <Run Text="Σ " Foreground="{DynamicResource TextMuted}" />
                <Run Text="{Binding WanTotalLabel}"
                     Foreground="{DynamicResource TextPrimary}" FontWeight="Medium" />
            </TextBlock>

            <!-- Device ID -->
            <TextBlock Grid.Column="4" FontSize="11" VerticalAlignment="Center"
                       Margin="24,0,0,0">
                <Run Text="DEV " Foreground="{DynamicResource TextMuted}"
                     FontWeight="Medium" />
                <Run Text="{Binding DeviceIdLabel}"
                     Foreground="{DynamicResource TextMuted}" />
            </TextBlock>

        </Grid>
    </Border>
</UserControl>
