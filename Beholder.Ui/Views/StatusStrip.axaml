<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Beholder.Ui.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="28"
             x:Class="Beholder.Ui.Views.StatusStrip"
             x:DataType="vm:MainWindowViewModel"
             Background="{DynamicResource BackgroundPanel}">

    <Border BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="0,1,0,0">
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,4">

            <!-- Throughput metrics -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Spacing="16">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="OUT"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="11" FontWeight="Medium"
                               LetterSpacing="1"
                               VerticalAlignment="Center" />
                    <TextBlock Text="0 B"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="IN"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="11" FontWeight="Medium"
                               LetterSpacing="1"
                               VerticalAlignment="Center" />
                    <TextBlock Text="0 B"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- WAN sparkline placeholder -->
            <Border Grid.Column="1"
                    Background="{DynamicResource BackgroundPanel}"
                    Height="14" Margin="24,0"
                    VerticalAlignment="Center" />

            <!-- Device ID -->
            <TextBlock Grid.Column="2"
                       Text="DEV-0000"
                       Foreground="{DynamicResource TextMuted}"
                       FontSize="11"
                       LetterSpacing="1"
                       VerticalAlignment="Center" />
        </Grid>
    </Border>
</UserControl>
