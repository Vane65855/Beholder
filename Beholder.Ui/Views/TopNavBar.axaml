<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Beholder.Ui.ViewModels"
             xmlns:views="using:Beholder.Ui.Views"
             xmlns:chrome="using:Avalonia.Controls.Chrome"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="44"
             x:Class="Beholder.Ui.Views.TopNavBar"
             x:DataType="vm:MainWindowViewModel"
             Background="{DynamicResource BackgroundNavBar}">

    <Border Background="Transparent"
            BorderBrush="{DynamicResource BorderSubtle}"
            BorderThickness="0,0,0,1"
            chrome:WindowDecorationProperties.ElementRole="TitleBar">
        <Grid ColumnDefinitions="Auto,*,Auto,*,Auto" Margin="16,8,0,8">

            <!-- Brand block -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Spacing="6">
                <TextBlock Text="BEHOLDER NMT"
                           Foreground="{DynamicResource AccentPrimary}"
                           FontWeight="SemiBold" FontSize="{DynamicResource FontSizeHeading}"
                           LetterSpacing="2"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding VersionLabel}"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="{DynamicResource FontSizeCaption}"
                           VerticalAlignment="Center" />
                <TextBlock Text=" ·  daemon:"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="{DynamicResource FontSizeCaption}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding DaemonStatusLabel}"
                           FontSize="{DynamicResource FontSizeCaption}"
                           VerticalAlignment="Center"
                           Classes.disconnected="{Binding IsDaemonDisconnected}"
                           Classes.connecting="{Binding IsDaemonConnecting}"
                           Classes.connected="{Binding IsDaemonConnected}" />
            </StackPanel>

            <!-- Tab buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" Spacing="4">

                <Button Command="{Binding SwitchTabCommand}"
                        CommandParameter="{x:Static vm:TabKind.Traffic}"
                        Classes="navTab"
                        chrome:WindowDecorationProperties.ElementRole="User"
                        Classes.active="{Binding IsTrafficActive}">
                    <TextBlock Text="{Binding TrafficLabel}" LetterSpacing="1.5" />
                </Button>

                <Button Command="{Binding SwitchTabCommand}"
                        CommandParameter="{x:Static vm:TabKind.Firewall}"
                        Classes="navTab"
                        chrome:WindowDecorationProperties.ElementRole="User"
                        Classes.active="{Binding IsFirewallActive}">
                    <TextBlock Text="{Binding FirewallLabel}" LetterSpacing="1.5" />
                </Button>

                <Button Command="{Binding SwitchTabCommand}"
                        CommandParameter="{x:Static vm:TabKind.Alerts}"
                        Classes="navTab"
                        chrome:WindowDecorationProperties.ElementRole="User"
                        Classes.active="{Binding IsAlertsActive}">
                    <TextBlock Text="{Binding AlertsLabel}" LetterSpacing="1.5" />
                </Button>

                <Button Command="{Binding SwitchTabCommand}"
                        CommandParameter="{x:Static vm:TabKind.Scanner}"
                        Classes="navTab"
                        chrome:WindowDecorationProperties.ElementRole="User"
                        Classes.active="{Binding IsScannerActive}">
                    <TextBlock Text="{Binding ScannerLabel}" LetterSpacing="1.5" />
                </Button>

                <Button Command="{Binding SwitchTabCommand}"
                        CommandParameter="{x:Static vm:TabKind.Settings}"
                        Classes="navTab"
                        chrome:WindowDecorationProperties.ElementRole="User"
                        Classes.active="{Binding IsSettingsActive}">
                    <TextBlock Text="{Binding SettingsLabel}" LetterSpacing="1.5" />
                </Button>
            </StackPanel>

            <!-- Window chrome buttons -->
            <views:WindowControls Grid.Column="4"
                                  VerticalAlignment="Stretch"
                                  Margin="0,-8,0,-8" />
        </Grid>
    </Border>

    <UserControl.Styles>
        <Style Selector="Button.navTab">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.navTab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
        <Style Selector="Button.navTab.active">
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentPrimary}" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
        </Style>
        <Style Selector="Button.navTab.active /template/ ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource AccentPrimary}" />
        </Style>

        <Style Selector="TextBlock.disconnected">
            <Setter Property="Foreground" Value="{DynamicResource StatusOffline}" />
        </Style>
        <Style Selector="TextBlock.connecting">
            <Setter Property="Foreground" Value="{DynamicResource StatusConnecting}" />
        </Style>
        <Style Selector="TextBlock.connected">
            <Setter Property="Foreground" Value="{DynamicResource StatusOnline}" />
        </Style>
    </UserControl.Styles>
</UserControl>
