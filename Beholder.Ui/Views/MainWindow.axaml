<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Beholder.Ui.ViewModels"
        xmlns:views="using:Beholder.Ui.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="Beholder.Ui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Beholder NMT"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="720"
        WindowDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="44"
        Background="{DynamicResource BackgroundRoot}">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <views:TopNavBar Grid.Row="0" />
        <ContentControl Grid.Row="1" Content="{Binding ActiveTabContent}" />
        <views:StatusStrip Grid.Row="2" />
    </Grid>
</Window>
